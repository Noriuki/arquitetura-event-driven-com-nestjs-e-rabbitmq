# Copie para `.env` local se quiser sobrescrever defaults.
# O `docker compose` injeta variáveis nos containers.

# -------- RabbitMQ --------
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RABBITMQ_EXCHANGE=order_exchange

# -------- Postgres (order: 5432, inventory: 5433, payment: 5434) --------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_db

# Migrations rodam no startup do app (padrão). Para desligar: TYPEORM_MIGRATIONS_RUN=false
# TYPEORM_MIGRATIONS_RUN=false

# -------- order-service --------
PORT=3000
ORDER_EVENTS_QUEUE=order_events_queue

# -------- inventory-service --------
QUEUE=inventory_queue
STOCK_INITIAL_QTY=100

# -------- payment-service --------
QUEUE=payment_queue
ROUTING_KEY=inventory.reserved
# FAIL_ORDER_ID=
# FAIL_PAYMENT_AMOUNT=77
